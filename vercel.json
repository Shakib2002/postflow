{
    "crons": [
        {
            "path": "/api/cron/publish-scheduled",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/retry-failed",
            "schedule": "0 1 * * *"
        }
    ],
    "functions": {
        "src/app/api/cron/publish-scheduled/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/publish/route.ts": {
            "maxDuration": 60
        }
    }
}